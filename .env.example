# Confluence 접속 정보
CONFLUENCE_BASE_URL=your_url
CONFLUENCE_EMAIL=your_email
CONFLUENCE_API_TOKEN=your_token
CONFLUENCE_SPACE_KEY=your_space_key

# 업로드 시작점: 콘텐츠를 붙일 루트 페이지 ID (Confluence에서 확인)
ROOT_PAGE_ID=your_root_page_id

# 임베딩 설정
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# ChromaDB 설정
VECTOR_DB_PATH=./vector_db
VECTOR_DB_COLLECTION=confluence
ANONYMIZED_TELEMETRY=False

# Confluence API 호출 설정
CONFLUENCE_FETCH_LIMIT=50    # 배치당 페이지 수 (최대 50)
CONFLUENCE_REQUEST_DELAY=1.0 # 배치 요청 사이 대기 시간 (초, 0=딜레이 없음)

# 청크 설정 (글자 수 기준)
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# LLM 설정 (챗봇)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key  # provider=anthropic 시 사용

# 리랭킹 모델 (cross-encoder, 로컬 무료)
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANK_FETCH_K=20       # 초기 후보 청크 수
RERANK_THRESHOLD=-2.0   # 이 점수 미만 페이지 제외 (로짓 기준)
